generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ REFERENCE TABLES ============

model FieldOfActivity {
  id   String @id @default(uuid())
  name String @unique
  nameNorm String? // generated (ё→е, lower) — search only, never written

  directions  Direction[]
  users       User[]

  createdAt DateTime @default(now())
}

model Direction {
  id                String           @id @default(uuid())
  name              String
  nameNorm          String? // generated (ё→е, lower) — search only, never written
  fieldOfActivityId String?
  fieldOfActivity   FieldOfActivity? @relation(fields: [fieldOfActivityId], references: [id], onDelete: SetNull)

  professions        Profession[]
  allowedFilterTypes String[]
  customFilters      CustomFilter[] @relation("DirectionCustomFilters")

  createdAt DateTime @default(now())

  @@unique([name, fieldOfActivityId])
  @@index([fieldOfActivityId])
}

model Profession {
  id          String     @id @default(uuid())
  name        String
  nameNorm    String? // generated (ё→е, lower) — search only, never written
  directionId String?
  direction   Direction? @relation(fields: [directionId], references: [id], onDelete: SetNull)

  userProfessions UserProfession[]
  userServices    UserService[]
  groupMembers    UserArtist[]
  connections     Connection[]
  customFilters   CustomFilter[] @relation("ProfessionCustomFilters")
  serviceProfessions ServiceProfession[]

  createdAt DateTime @default(now())

  @@index([directionId])
}

// Section — top-level grouping for services (catalog cards)
model Section {
  id        String   @id @default(uuid())
  name      String   @unique
  sortOrder Int      @default(0)
  services  Service[]
  createdAt DateTime @default(now())
}

// ============ SEARCH FILTER MODELS ============

// Service — standalone reference item (no longer attached to directions via M2M)
model Service {
  id        String      @id @default(uuid())
  name      String
  nameNorm  String? // generated (ё→е, lower) — search only, never written
  sortOrder Int         @default(0)

  sectionId String?
  section   Section?    @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  serviceProfessions ServiceProfession[]
  customFilters      CustomFilter[] @relation("ServiceCustomFilters")

  userServices       UserService[]
  connectionServices ConnectionService[]
  reviews            Review[]
  deals              Deal[]

  createdAt DateTime @default(now())

  @@index([sectionId])
}

// Explicit M2M join: services ↔ professions
model ServiceProfession {
  serviceId    String
  professionId String
  service      Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  profession   Profession @relation(fields: [professionId], references: [id], onDelete: Cascade)
  @@id([serviceId, professionId])
  @@index([professionId])
}

// Independent filter: music genres
model Genre {
  id        String @id @default(uuid())
  name      String @unique
  nameNorm  String? // generated (ё→е, lower) — search only, never written
  nameEn    String?
  sortOrder Int    @default(0)

  userServices UserService[]
  artists      ArtistGenre[]

  createdAt DateTime @default(now())
}

// Independent filter: work format
model WorkFormat {
  id        String @id @default(uuid())
  name      String @unique
  nameNorm  String? // generated (ё→е, lower) — search only, never written
  nameEn    String?
  sortOrder Int    @default(0)

  userServices UserService[]

  createdAt DateTime @default(now())
}

// Independent filter: employment type
model EmploymentType {
  id        String @id @default(uuid())
  name      String @unique
  nameNorm  String? // generated (ё→е, lower) — search only, never written
  nameEn    String?
  sortOrder Int    @default(0)

  userServices UserService[]

  createdAt DateTime @default(now())
}

// Independent filter: skill level
model SkillLevel {
  id        String @id @default(uuid())
  name      String @unique
  nameNorm  String? // generated (ё→е, lower) — search only, never written
  nameEn    String?
  sortOrder Int    @default(0)

  userServices UserService[]

  createdAt DateTime @default(now())
}

// Independent filter: availability
model Availability {
  id        String @id @default(uuid())
  name      String @unique
  nameNorm  String? // generated (ё→е, lower) — search only, never written
  nameEn    String?
  sortOrder Int    @default(0)

  userServices UserService[]

  createdAt DateTime @default(now())
}

// Independent filter: geography (cities / regions)
model Geography {
  id        String @id @default(uuid())
  name      String @unique
  nameNorm  String? // generated (ё→е, lower) — search only, never written
  nameEn    String?
  sortOrder Int    @default(0)

  userServices UserService[]

  createdAt DateTime @default(now())
}

// Independent filter: price range (discrete buckets)
model PriceRange {
  id        String @id @default(uuid())
  name      String @unique  // e.g. "До 5 000 ₽"
  nameEn    String?
  minValue  Int?
  maxValue  Int?
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())
}

// Per-user service offering: profession → service → own filter set
model UserService {
  id           String     @id @default(uuid())
  userId       String
  professionId String
  serviceId    String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profession Profession @relation(fields: [professionId], references: [id])
  service    Service    @relation(fields: [serviceId], references: [id])

  genres                     Genre[]
  workFormats                WorkFormat[]
  employmentTypes            EmploymentType[]
  skillLevels                SkillLevel[]
  availabilities             Availability[]
  geographies                Geography[]
  name                       String?
  nameNorm                   String? // generated (ё→е, lower) — search only, never written
  priceFrom                  Int?
  priceTo                    Int?
  deadlineFrom               Int?
  deadlineTo                 Int?
  description                String?
  priceItems                 Json?
  status                     String    @default("active")
  selectedCustomFilterValues CustomFilterValue[]
  deals                      Deal[]
  posts                      Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, serviceId])
  @@index([userId])
  @@index([professionId])
  @@index([serviceId])
}

// ============ OTHER REFERENCE TABLES ============

model ProfessionFeature {
  id   String @id @default(uuid())
  name String @unique

  createdAt DateTime @default(now())
}

// ============ CONNECTIONS ============

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
  BREAK_REQUESTED
}

model Connection {
  id                    String           @id @default(uuid())
  requesterId           String
  receiverId            String
  status                ConnectionStatus @default(PENDING)
  breakRequestedBy      String?
  breakReasonRequester  String?
  breakReasonReceiver   String?
  professionId          String?
  requesterRole         String?
  receiverRole          String?
  needsDeal             Boolean @default(false)

  requester     User        @relation("ConnectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver      User        @relation("ConnectionReceiver",  fields: [receiverId],  references: [id], onDelete: Cascade)
  profession    Profession? @relation(fields: [professionId], references: [id], onDelete: SetNull)

  services      ConnectionService[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requesterId])
  @@index([receiverId])
  @@index([status])
}

model ConnectionHistory {
  id                   String   @id @default(uuid())
  requesterId          String
  receiverId           String
  professionId         String?
  breakInitiatorId     String
  breakReasonRequester String?
  breakReasonReceiver  String?
  connectedAt          DateTime
  endedAt              DateTime @default(now())

  requester User @relation("ConnHistoryRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("ConnHistoryReceiver",  fields: [receiverId],  references: [id], onDelete: Cascade)

  @@index([requesterId])
  @@index([receiverId])
}

model ConnectionService {
  connectionId String
  serviceId    String
  connection   Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  service      Service    @relation(fields: [serviceId],    references: [id], onDelete: Cascade)
  @@id([connectionId, serviceId])
}

enum ArtistType {
  SOLO
  GROUP
  COVER_GROUP
  DUET
  TRIBUTE
  CHOIR
  ENSEMBLE
  ORCHESTRA
}

enum ArtistActivityStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  DISBANDED
}

enum MemberParticipationStatus {
  ACTIVE_MEMBER
  FORMER_MEMBER
}

enum RoleContext {
  COLLECTIVE
  RELEASE
  CLIP
}

enum StreamingPlatform {
  VK
  SPOTIFY
  YANDEX_MUSIC
  APPLE_MUSIC
}

enum ClipPlatform {
  VK_VIDEO
  RUTUBE
  YOUTUBE
}

enum ContactsVisibility {
  ALL
  REGISTERED
  FRIENDS
}

enum ArtistStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  VERIFIED
}

model Artist {
  id          String       @id @default(uuid())
  name        String
  nameNorm    String? // generated (ё→е, lower) — search only, never written
  type        ArtistType?
  city        String?
  tourReady   String?
  description String?
  socialLinks Json?
  bandLink    String?
  avatar      String?
  banner      String?
  listeners   BigInt       @default(0)

  activityStatus       ArtistActivityStatus @default(ACTIVE)

  status               ArtistStatus @default(DRAFT)
  submittedById        String?
  submittedByUser      User?        @relation("ArtistSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  rejectionReason      String?
  verificationCode     String?      @unique
  verificationProofUrl String?
  moderatedAt          DateTime?
  submitterRoles       String[]     @default([])

  genres      ArtistGenre[]
  userArtists UserArtist[]
  followers   ArtistFollower[]
  posts       Post[]
  releases    Release[]
  clips       Clip[]
  invites     ArtistInvite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([submittedById])
}

model ArtistGenre {
  artistId String
  genreId  String
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  genre    Genre  @relation(fields: [genreId], references: [id], onDelete: Cascade)
  @@id([artistId, genreId])
}

model ArtistFollower {
  userId    String
  artistId  String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist    Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@id([userId, artistId])
}

model Employer {
  id   String  @id @default(uuid())
  name String
  inn  String? @unique
  ogrn String? @unique

  users User[]

  createdAt DateTime @default(now())
}

model PortfolioFile {
  id           String  @id @default(uuid())
  userId       String
  url          String
  originalName String
  size         Int
  mimeType     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

model PortfolioLink {
  id        String   @id @default(uuid())
  userId    String
  type      String   // 'audio' | 'video'
  url       String
  title     String   @default("")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============ USER MODEL ============

// Holds an in-progress email/password signup until the emailed code is verified.
// No User row (or any related record) exists until verification succeeds — at
// which point the account is created from this payload and the row is deleted.
model PendingRegistration {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  payload      Json     // profile fields captured at signup (firstName, lastName, phone, city, professions, referral, …)
  code         String
  expiresAt    DateTime
  lastSentAt   DateTime @default(now())
  createdAt    DateTime @default(now())
}

model User {
  id        String   @id @default(uuid())
  email     String?  @unique
  phone     String?  @unique
  password  String?
  telegramId       String?  @unique
  telegramUsername String?
  vkId             String?  @unique
  firstName String
  lastName  String
  nickname  String?
  avatar      String?
  bannerImage String?
  bio       String?
  country   String?
  city      String?
  // Generated normalized copies (ё→е, lower) for ё/е-insensitive search — never written
  firstNameNorm String?
  lastNameNorm  String?
  nicknameNorm  String?
  bioNorm       String?
  countryNorm   String?
  cityNorm      String?
  emailNorm     String?
  role      String?
  isAdmin   Boolean  @default(false)
  isBlocked  Boolean  @default(false)
  blockedUntil DateTime?
  isPremium  Boolean  @default(false)
  isPro      Boolean  @default(false)          // manual permanent Pro override (admin)
  proUntil   DateTime?                          // time-based Pro expiry (donation/referral); effective Pro = isPro || proUntil>now
  proMonthsFromReferrals Int @default(0)        // referral-granted Pro months already applied (to compute deltas)
  isVerified Boolean  @default(false)
  emailVerified          Boolean   @default(false)
  emailVerificationCode  String?
  emailVerificationExpires DateTime?
  passwordResetCode      String?
  passwordResetExpires   DateTime?
  passwordChangedAt      DateTime?
  lastCodeSentAt         DateTime?
  genres    String[]
  professions String[] // legacy flat list, kept for backward compat

  // Field of Activity (reference)
  fieldOfActivityId String?
  fieldOfActivity   FieldOfActivity? @relation(fields: [fieldOfActivityId], references: [id])

  // Multi-level professions (relational)
  userProfessions UserProfession[]

  // Per-service offerings with own filter sets
  userServices UserService[]

  // Artist / Group (many-to-many)
  userArtists      UserArtist[]
  groupInvitesSent UserArtist[] @relation("GroupInviter")
  artistFollows    ArtistFollower[]
  submittedArtists Artist[]        @relation("ArtistSubmitter")

  // Connections
  sentConnections     Connection[] @relation("ConnectionRequester")
  receivedConnections Connection[] @relation("ConnectionReceiver")

  // Connection history
  sentConnHistory     ConnectionHistory[] @relation("ConnHistoryRequester")
  receivedConnHistory ConnectionHistory[] @relation("ConnHistoryReceiver")

  // Favorites
  favorites   Favorite[] @relation("FavoriteAdder")
  favoritedBy Favorite[] @relation("FavoriteTarget")

  portfolioFiles PortfolioFile[]
  portfolioLinks PortfolioLink[]

  // Employer (many-to-one)
  employerId String?
  employer   Employer? @relation(fields: [employerId], references: [id])

  // Social links — JSON map: { tg_profile?: string, tg_channel?: string, vk_profile?: string, ... }
  socialLinks  Json?

  // Relationships
  posts        Post[]
  likes        Like[]
  pollVotes    PollVote[]
  savedPosts   SavedPost[]
  comments     Comment[]
  postReactions    PostReaction[]
  commentReactions CommentReaction[]
  messageReactions MessageReaction[]
  sentRequests Friendship[] @relation("SentRequests")
  receivedRequests Friendship[] @relation("ReceivedRequests")
  sentMessages Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  conversationMembers ConversationMember[]
  pushSubscriptions    PushSubscription[]
  notifications        Notification[] @relation("NotificationRecipient")
  triggeredNotifications Notification[] @relation("NotificationActor")

  channel              Channel?
  channelSubscriptions ChannelSubscription[]

  // Referrals
  referrerId String?
  referrer   User?  @relation("UserReferrals", fields: [referrerId], references: [id], onDelete: SetNull)
  referrals  User[] @relation("UserReferrals")

  // Single-use referral links the user generates
  referralLinks    ReferralLink[] @relation("ReferralLinkOwner")
  usedReferralLink ReferralLink?  @relation("ReferralLinkConsumer")
  referralLinkUsed String?        // code of the ReferralLink this user signed up through

  // Pro
  donationCodes DonationCode[]
  feedPresets   FeedPreset[]

  reviewsGiven    Review[] @relation("ReviewAuthor")
  reviewsReceived Review[] @relation("ReviewTarget")

  complaintsFiled Complaint[] @relation("ComplaintReporter")

  dealsAsCustomer Deal[] @relation("DealCustomer")
  dealsAsExecutor Deal[] @relation("DealExecutor")
  dealEditRequests DealEditRequest[] @relation("DealEditRequester")

  occupancyStatus  String?  // 'closed' | 'considering' | 'open'

  birthDate             DateTime?
  birthDateVisible      Boolean   @default(false)
  contactsVisible       Boolean   @default(true)
  contactsVisibility    ContactsVisibility @default(ALL)

  // Release / Clip participation
  releaseParticipations ReleaseParticipant[]
  clipParticipations    ClipParticipant[]
  lastSeenAt            DateTime?
  termsAgreedAt         DateTime?
  onboardingCompletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([city])
  @@index([role])
  @@index([fieldOfActivityId])
  @@index([employerId])
  @@index([referrerId])
}

model Review {
  id        String   @id @default(uuid())
  authorId  String
  targetId  String
  rating    Int      // 1-10
  text      String?
  reply     String?
  type      String   @default("connection") // 'connection' | 'deal'
  serviceId String?
  dealId    String?

  author  User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  target  User     @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([authorId, targetId, type])
  @@index([targetId])
  @@index([authorId])
  @@index([dealId])
}

model Complaint {
  id          String   @id @default(uuid())
  reporterId  String
  targetType  String   // 'user' | 'post' | 'review'
  targetId    String
  category    String
  text        String?
  riskScore   Int      @default(0)
  status      String   @default("pending")  // pending | reviewed | actioned | rejected
  resolution  String?
  resolvedAt  DateTime?

  reporter User @relation("ComplaintReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([targetType, targetId])
  @@index([status])
}

model Deal {
  id             String    @id @default(uuid())
  title          String
  status         String    @default("PENDING")
  // Type A: PENDING | AWAITING_PAYMENT | IN_PROGRESS | REVIEW | REVISION | COMPLETED | CANCELLED
  // Type B: PENDING | AWAITING_PAYMENT | AWAITING_EVENT | AWAITING_CONFIRMATION | COMPLETED | CANCELLED
  dealType       String    @default("process")  // 'process' | 'event'
  customerId     String
  executorId     String
  serviceId      String?
  userServiceId  String?
  price          Float?
  deadline       DateTime?
  acceptDeadline DateTime?
  revisionCount  Int       @default(3)
  revisionsUsed  Int       @default(0)
  result         String?
  cancelReason   String?
  eventDate      DateTime?
  deposit        Float?

  customer    User         @relation("DealCustomer",  fields: [customerId],   references: [id], onDelete: Cascade)
  executor    User         @relation("DealExecutor",  fields: [executorId],   references: [id], onDelete: Cascade)
  service     Service?     @relation(fields: [serviceId],    references: [id], onDelete: SetNull)
  userService UserService? @relation(fields: [userServiceId], references: [id], onDelete: SetNull)
  reviews     Review[]
  editRequests DealEditRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([executorId])
  @@index([status])
}

model DealEditRequest {
  id          String   @id @default(uuid())
  dealId      String
  requesterId String
  status      String   @default("PENDING")  // PENDING | APPROVED | REJECTED
  changes     Json     // {deadline?, acceptDeadline?, revisionCount?}

  deal      Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  requester User @relation("DealEditRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Single-use referral links the user generates. Each link admits exactly one signup.
model ReferralLink {
  id        String   @id @default(uuid())
  code      String   @unique          // short slug used in /register?ref=<code>
  label     String                    // human label set by the owner
  ownerId   String
  owner     User     @relation("ReferralLinkOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  clicks    Int      @default(0)      // optional click tracking

  // Consumption — a link is "burned" after the first registration
  usedById  String?  @unique          // the user who registered through this link
  usedBy    User?    @relation("ReferralLinkConsumer", fields: [usedById], references: [id], onDelete: SetNull)
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([ownerId])
  @@index([code])
}

// ============ JOIN TABLES ============

model UserProfession {
  id           String     @id @default(uuid())
  userId       String
  professionId String
  features     String[]   // selected feature names (e.g. "Начинающий", "Платно")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profession Profession @relation(fields: [professionId], references: [id])

  selectedCustomFilterValues CustomFilterValue[]

  createdAt DateTime @default(now())

  @@unique([userId, professionId])
  @@index([userId])
  @@index([professionId])
}

enum GroupInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  ARCHIVED
}

model UserArtist {
  id           String            @id @default(uuid())
  userId       String
  artistId     String
  isOwner             Boolean                   @default(false)
  isAdmin             Boolean                   @default(false)
  professionId        String?
  inviteStatus        GroupInviteStatus         @default(ACCEPTED)
  participationStatus MemberParticipationStatus @default(ACTIVE_MEMBER)
  // True when the member was demoted to FORMER automatically because the artist
  // left ACTIVE. Lets reactivation restore exactly those members (and not the
  // ones an admin manually marked as former). Cleared on any manual change.
  autoFormered        Boolean                   @default(false)
  invitedById         String?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist     Artist      @relation(fields: [artistId], references: [id], onDelete: Cascade)
  profession Profession? @relation(fields: [professionId], references: [id], onDelete: SetNull)
  invitedBy  User?       @relation("GroupInviter", fields: [invitedById], references: [id], onDelete: SetNull)
  roles      UserArtistRole[]

  createdAt DateTime @default(now())

  @@unique([userId, artistId, professionId])
  @@index([userId])
  @@index([artistId])
  @@index([inviteStatus])
}

model ArtistInvite {
  id                  String                    @id @default(uuid())
  artistId            String
  token               String                    @unique
  roleIds             String[]                  @default([])
  participationStatus MemberParticipationStatus @default(ACTIVE_MEMBER)
  createdById         String?
  createdAt           DateTime                  @default(now())

  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId])
}

// ============ ROLE CATALOG ============

model Role {
  id        String      @id @default(uuid())
  name      String
  context   RoleContext
  category  String
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())

  userArtistRoles         UserArtistRole[]
  releaseParticipantRoles ReleaseParticipantRole[]
  clipParticipantRoles    ClipParticipantRole[]

  @@unique([context, category, name])
  @@index([context, category])
}

model UserArtistRole {
  id           String @id @default(uuid())
  userArtistId String
  roleId       String

  userArtist UserArtist @relation(fields: [userArtistId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userArtistId, roleId])
}

// ============ RELEASES ============

model Release {
  id          String            @id @default(uuid())
  artistId    String
  title       String
  coverUrl    String?
  releaseDate DateTime?
  platform    StreamingPlatform
  url         String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  artist       Artist               @relation(fields: [artistId], references: [id], onDelete: Cascade)
  participants ReleaseParticipant[]

  @@index([artistId])
}

model ReleaseParticipant {
  id            String            @id @default(uuid())
  releaseId     String
  userId        String
  confirmStatus GroupInviteStatus @default(PENDING)
  createdAt     DateTime          @default(now())

  release Release                  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  user    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles   ReleaseParticipantRole[]

  @@unique([releaseId, userId])
}

model ReleaseParticipantRole {
  id            String @id @default(uuid())
  participantId String
  roleId        String

  participant ReleaseParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  role        Role               @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([participantId, roleId])
}

// ============ CLIPS ============

model Clip {
  id        String       @id @default(uuid())
  artistId  String
  title     String
  coverUrl  String?
  platform  ClipPlatform
  url       String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  artist       Artist            @relation(fields: [artistId], references: [id], onDelete: Cascade)
  participants ClipParticipant[]

  @@index([artistId])
}

model ClipParticipant {
  id            String            @id @default(uuid())
  clipId        String
  userId        String
  confirmStatus GroupInviteStatus @default(PENDING)
  createdAt     DateTime          @default(now())

  clip  Clip                  @relation(fields: [clipId], references: [id], onDelete: Cascade)
  user  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles ClipParticipantRole[]

  @@unique([clipId, userId])
}

model ClipParticipantRole {
  id            String @id @default(uuid())
  participantId String
  roleId        String

  participant ClipParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  role        Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([participantId, roleId])
}

// ============ EXISTING MODELS ============

model Channel {
  id          String  @id @default(uuid())
  name        String
  description String?
  avatar      String?
  ownerId     String  @unique
  owner       User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  posts         Post[]
  subscriptions ChannelSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model ChannelSubscription {
  id        String @id @default(uuid())
  channelId String
  userId    String

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([channelId, userId])
  @@index([channelId])
  @@index([userId])
}

model Post {
  id        String  @id @default(uuid())
  content   String
  type      String  @default("blog")
  imageUrl  String?
  audioUrl  String?
  audioName String?

  pollOptions Json?
  pollEndsAt  DateTime?

  // ─── E10: MVP feed foundation ───────────────────────────────────────────────
  title    String?   // "Вопрос/обсуждение": заголовок
  category String?   // "Вопрос/обсуждение": категория
  city     String?   // опциональный город поста (из каталога)
  images   String[] @default([])   // мультифото (до 10)
  tags     String[] @default([])   // свободные #теги
  genres   String[] @default([])   // жанры (мультиселект, опц.)
  links    String[] @default([])   // свободные ссылки
  mentions Json?                    // [{ id, type, name }]

  // Репост в ленту: ссылка на оригинальный пост + опциональный комментарий
  repostComment String?
  repostDeleted Boolean @default(false)
  repostOfId    String?
  repostOf      Post?   @relation("PostReposts", fields: [repostOfId], references: [id], onDelete: SetNull)
  reposts       Post[]  @relation("PostReposts")

  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  channelId String?
  channel   Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  artistId String?
  artist   Artist? @relation(fields: [artistId], references: [id], onDelete: SetNull)

  // Structured "Услуга" post — link to the offering it advertises (for the
  // «Детали услуги» button and to derive section/price at render time).
  serviceId String?
  service   UserService? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  likes     Like[]
  comments  Comment[]
  reactions PostReaction[]
  pollVotes PollVote[]
  savedBy   SavedPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
  @@index([createdAt])
  @@index([authorId, createdAt])
  @@index([channelId])
  @@index([artistId])
  @@index([repostOfId])
  @@index([type])
  @@index([city])
}

model PollVote {
  id          String   @id @default(uuid())
  postId      String
  userId      String
  optionIndex Int

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model SavedPost {
  id     String @id @default(uuid())
  userId String
  postId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([userId])
}

model Like {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String

  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
}

model Comment {
  id      String @id @default(uuid())
  content String

  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String

  parentComment   Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  parentCommentId String?
  replies         Comment[] @relation("CommentReplies")

  reactions CommentReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([authorId])
  @@index([postId, createdAt])
  @@index([parentCommentId])
}

model Conversation {
  id        String   @id @default(uuid())
  name      String?
  avatar    String?
  isGroup   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  ConversationMember[]
  messages Message[]

  @@index([updatedAt])
}

model ConversationMember {
  id             String    @id @default(uuid())
  conversationId String
  userId         String
  isAdmin        Boolean   @default(false)
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime?
  isPinned       Boolean   @default(false)
  isArchived     Boolean   @default(false)
  type           String    @default("personal")
  deletedAt      DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String    @id @default(uuid())
  conversationId String?
  senderId       String
  receiverId     String?
  content        String    @default("")
  contentNorm    String? // generated (ё→е, lower) — search only, never written
  replyToId      String?
  isEdited       Boolean   @default(false)
  attachmentUrl  String?
  attachmentName String?
  attachmentSize Int?
  attachmentType String?
  deletedAt      DateTime?
  deliveredAt    DateTime?
  readAt         DateTime?

  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver     User?         @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  replyTo      Message?      @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]     @relation("MessageReplies")
  reactions    MessageReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([receiverId, readAt])
  @@index([conversationId, deliveredAt])
  @@index([senderId, receiverId, createdAt])
}

model Friendship {
  id String @id @default(uuid())

  requester   User   @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  requesterId String

  receiver   User   @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  receiverId String

  status String // pending, accepted, rejected

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([requesterId, receiverId])
  @@index([requesterId])
  @@index([receiverId])
  @@index([status])
  @@index([receiverId, status])
  @@index([requesterId, status])
}

// ============ PUSH SUBSCRIPTIONS ============

model PushSubscription {
  id       String @id @default(uuid())
  userId   String
  endpoint String @unique
  p256dh   String
  auth     String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ============ CUSTOM FILTERS ============

model CustomFilter {
  id           String              @id @default(uuid())
  name         String
  values       CustomFilterValue[]
  filterValues String[]
  directions   Direction[]         @relation("DirectionCustomFilters")
  professionId String?
  profession   Profession?         @relation("ProfessionCustomFilters", fields: [professionId], references: [id], onDelete: Cascade)
  serviceId    String?
  service      Service?            @relation("ServiceCustomFilters", fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt    DateTime            @default(now())

  @@unique([name, professionId])
  @@unique([name, serviceId])
  @@index([professionId])
  @@index([serviceId])
}

model CustomFilterValue {
  id        String       @id @default(uuid())
  value     String
  valueNorm String? // generated (ё→е, lower) — search only, never written
  sortOrder Int          @default(0)
  filterId  String
  filter    CustomFilter @relation(fields: [filterId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  userServices    UserService[]
  userProfessions UserProfession[]

  @@index([filterId])
}

// ============ REACTIONS ============

model PostReaction {
  id     String @id @default(uuid())
  emoji  String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
}

model CommentReaction {
  id    String @id @default(uuid())
  emoji String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId])
}

model MessageReaction {
  id    String @id @default(uuid())
  emoji String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, messageId])
  @@index([messageId])
}

// ============ FAVORITES ============

model Favorite {
  id       String @id @default(uuid())
  userId   String
  targetId String
  user     User   @relation("FavoriteAdder", fields: [userId],   references: [id], onDelete: Cascade)
  target   User   @relation("FavoriteTarget", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, targetId])
  @@index([userId])
}

// ============ NOTIFICATIONS ============

model Notification {
  id      String  @id @default(uuid())
  // Recipient
  userId  String
  user    User    @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  // Who triggered
  actorId String?
  actor   User?   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  // Content
  type    String  // message | friend_request | friend_accepted | post_reply
  title   String
  body    String
  link    String? // route to navigate on click
  read    Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
  @@index([userId, createdAt])
}

// ============ PRO / DONATIONS ============

enum DonationStatus {
  CREATED   // code generated, not yet paid
  PAID      // payment seen (optional intermediate state)
  ACTIVATED // team verified payment and granted a Pro month
}

// One-time donation code (MOOOZA-XXXX) shown to the user before paying via CloudTips.
// Each time the donate screen opens, a new code is issued and the previous one is
// deactivated. The team matches the code from the payment comment to activate Pro.
model DonationCode {
  id          String         @id @default(uuid())
  code        String         @unique          // MOOOZA-XXXX
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      DonationStatus @default(CREATED)
  active      Boolean        @default(true)   // false once superseded by a newer code
  amount      Int?                            // RUB, filled in at verification (optional)
  note        String?                         // free-form admin note
  createdAt   DateTime       @default(now())
  paidAt      DateTime?
  activatedAt DateTime?

  @@index([userId])
  @@index([code])
  @@index([status])
}

// Saved feed-filter preset (Pro: multiple presets, free: a single one).
model FeedPreset {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  filters   Json                              // serialized FlowFilters
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
