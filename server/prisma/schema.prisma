generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ REFERENCE TABLES ============

model FieldOfActivity {
  id   String @id @default(uuid())
  name String @unique

  directions  Direction[]
  users       User[]

  createdAt DateTime @default(now())
}

model Direction {
  id                String          @id @default(uuid())
  name              String
  fieldOfActivityId String
  fieldOfActivity   FieldOfActivity @relation(fields: [fieldOfActivityId], references: [id])

  professions Profession[]

  createdAt DateTime @default(now())

  @@unique([name, fieldOfActivityId])
  @@index([fieldOfActivityId])
}

model Profession {
  id          String    @id @default(uuid())
  name        String
  directionId String
  direction   Direction @relation(fields: [directionId], references: [id])

  userProfessions UserProfession[]
  services        Service[]
  userServices    UserService[]

  createdAt DateTime @default(now())

  @@unique([name, directionId])
  @@index([directionId])
}

// ============ SEARCH FILTER MODELS ============

// Services offered — linked to Profession (hierarchical filter level 3)
model Service {
  id                 String     @id @default(uuid())
  name               String     @unique
  nameEn             String?
  sortOrder          Int        @default(0)
  professionId       String
  profession         Profession @relation(fields: [professionId], references: [id])
  allowedFilterTypes String[]   // system filter type keys, e.g. ["genre", "workFormat"]

  userServices  UserService[]
  customFilters CustomFilter[] @relation("ServiceCustomFilters")

  createdAt DateTime @default(now())
}

// Independent filter: music genres
model Genre {
  id        String @id @default(uuid())
  name      String @unique
  nameEn    String?
  sortOrder Int    @default(0)

  userServices UserService[]

  createdAt DateTime @default(now())
}

// Independent filter: work format
model WorkFormat {
  id        String @id @default(uuid())
  name      String @unique
  nameEn    String?
  sortOrder Int    @default(0)

  userServices UserService[]

  createdAt DateTime @default(now())
}

// Independent filter: employment type
model EmploymentType {
  id        String @id @default(uuid())
  name      String @unique
  nameEn    String?
  sortOrder Int    @default(0)

  userServices UserService[]

  createdAt DateTime @default(now())
}

// Independent filter: skill level
model SkillLevel {
  id        String @id @default(uuid())
  name      String @unique
  nameEn    String?
  sortOrder Int    @default(0)

  userServices UserService[]

  createdAt DateTime @default(now())
}

// Independent filter: availability
model Availability {
  id        String @id @default(uuid())
  name      String @unique
  nameEn    String?
  sortOrder Int    @default(0)

  userServices UserService[]

  createdAt DateTime @default(now())
}

// Independent filter: geography (cities / regions)
model Geography {
  id        String @id @default(uuid())
  name      String @unique
  nameEn    String?
  sortOrder Int    @default(0)

  userServices UserService[]

  createdAt DateTime @default(now())
}

// Independent filter: price range (discrete buckets)
model PriceRange {
  id        String @id @default(uuid())
  name      String @unique  // e.g. "До 5 000 ₽"
  nameEn    String?
  minValue  Int?
  maxValue  Int?
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())
}

// Per-user service offering: profession → service → own filter set
model UserService {
  id           String     @id @default(uuid())
  userId       String
  professionId String
  serviceId    String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profession Profession @relation(fields: [professionId], references: [id])
  service    Service    @relation(fields: [serviceId], references: [id])

  genres                     Genre[]
  workFormats                WorkFormat[]
  employmentTypes            EmploymentType[]
  skillLevels                SkillLevel[]
  availabilities             Availability[]
  geographies                Geography[]
  priceFrom                  Int?
  priceTo                    Int?
  selectedCustomFilterValues CustomFilterValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, serviceId])
  @@index([userId])
  @@index([professionId])
  @@index([serviceId])
}

// ============ OTHER REFERENCE TABLES ============

model ProfessionFeature {
  id   String @id @default(uuid())
  name String @unique

  createdAt DateTime @default(now())
}

model Artist {
  id   String @id @default(uuid())
  name String @unique

  userArtists UserArtist[]

  createdAt DateTime @default(now())
}

model Employer {
  id   String  @id @default(uuid())
  name String
  inn  String? @unique
  ogrn String? @unique

  users User[]

  createdAt DateTime @default(now())
}

model PortfolioFile {
  id           String  @id @default(uuid())
  userId       String
  url          String
  originalName String
  size         Int
  mimeType     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
}

// ============ USER MODEL ============

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  phone     String?  @unique
  password  String
  firstName String
  lastName  String
  nickname  String?
  avatar      String?
  bannerImage String?
  bio       String?
  country   String?
  city      String?
  role      String?
  isAdmin   Boolean  @default(false)
  genres    String[]
  professions String[] // legacy flat list, kept for backward compat

  // Field of Activity (reference)
  fieldOfActivityId String?
  fieldOfActivity   FieldOfActivity? @relation(fields: [fieldOfActivityId], references: [id])

  // Multi-level professions (relational)
  userProfessions UserProfession[]

  // Per-service offerings with own filter sets
  userServices UserService[]

  // Artist / Group (many-to-many)
  userArtists UserArtist[]

  portfolioFiles PortfolioFile[]

  // Employer (many-to-one)
  employerId String?
  employer   Employer? @relation(fields: [employerId], references: [id])

  // Social links
  vkLink       String?
  youtubeLink  String?
  telegramLink String?

  // Relationships
  posts        Post[]
  likes        Like[]
  comments     Comment[]
  sentRequests Friendship[] @relation("SentRequests")
  receivedRequests Friendship[] @relation("ReceivedRequests")
  sentMessages Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  conversationMembers ConversationMember[]
  pushSubscriptions    PushSubscription[]
  notifications        Notification[] @relation("NotificationRecipient")
  triggeredNotifications Notification[] @relation("NotificationActor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([city])
  @@index([role])
  @@index([fieldOfActivityId])
  @@index([employerId])
}

// ============ JOIN TABLES ============

model UserProfession {
  id           String     @id @default(uuid())
  userId       String
  professionId String
  features     String[]   // selected feature names (e.g. "Начинающий", "Платно")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profession Profession @relation(fields: [professionId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, professionId])
  @@index([userId])
  @@index([professionId])
}

model UserArtist {
  id       String @id @default(uuid())
  userId   String
  artistId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, artistId])
  @@index([userId])
  @@index([artistId])
}

// ============ EXISTING MODELS ============

model Post {
  id       String @id @default(uuid())
  content  String
  imageUrl String?

  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  likes    Like[]
  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
  @@index([createdAt])
  @@index([authorId, createdAt])
}

model Like {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String

  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
}

model Comment {
  id      String @id @default(uuid())
  content String

  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([authorId])
  @@index([postId, createdAt])
}

model Conversation {
  id        String   @id @default(uuid())
  name      String?
  avatar    String?
  isGroup   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  ConversationMember[]
  messages Message[]

  @@index([updatedAt])
}

model ConversationMember {
  id             String    @id @default(uuid())
  conversationId String
  userId         String
  isAdmin        Boolean   @default(false)
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String    @id @default(uuid())
  conversationId String?
  senderId       String
  receiverId     String?
  content        String    @default("")
  replyToId      String?
  isEdited       Boolean   @default(false)
  attachmentUrl  String?
  attachmentName String?
  attachmentSize Int?
  attachmentType String?
  deletedAt      DateTime?
  readAt         DateTime?

  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver     User?         @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  replyTo      Message?      @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]     @relation("MessageReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([receiverId, readAt])
  @@index([senderId, receiverId, createdAt])
}

model Friendship {
  id String @id @default(uuid())

  requester   User   @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  requesterId String

  receiver   User   @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  receiverId String

  status String // pending, accepted, rejected

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([requesterId, receiverId])
  @@index([requesterId])
  @@index([receiverId])
  @@index([status])
  @@index([receiverId, status])
  @@index([requesterId, status])
}

// ============ PUSH SUBSCRIPTIONS ============

model PushSubscription {
  id       String @id @default(uuid())
  userId   String
  endpoint String @unique
  p256dh   String
  auth     String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ============ CUSTOM FILTERS ============

model CustomFilter {
  id        String              @id @default(uuid())
  name      String
  values    CustomFilterValue[]
  services  Service[]           @relation("ServiceCustomFilters")
  createdAt DateTime            @default(now())
}

model CustomFilterValue {
  id        String       @id @default(uuid())
  value     String
  sortOrder Int          @default(0)
  filterId  String
  filter    CustomFilter @relation(fields: [filterId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  userServices UserService[]

  @@index([filterId])
}

// ============ NOTIFICATIONS ============

model Notification {
  id      String  @id @default(uuid())
  // Recipient
  userId  String
  user    User    @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  // Who triggered
  actorId String?
  actor   User?   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  // Content
  type    String  // message | friend_request | friend_accepted | post_reply
  title   String
  body    String
  link    String? // route to navigate on click
  read    Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
  @@index([userId, createdAt])
}
